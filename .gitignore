# WordPress sensitive files
wp-config.php
wp-config-local.php
wp-content/wp-cache-config.php
wp-content/wp-cache-config.php-old

# Generated / transient content (uploads are tracked — see wp-content/uploads/)
wp-content/upgrade/
wp-content/upgrade-temp-backup/
wp-content/upgrade-temp-backup-old/
wp-content/cache/
wp-content/boost-cache/
wp-content/boost-cache-old/
wp-content/updraft/
wp-content/backup*/
wp-content/*-old/
wp-content/*.php-old
wp-content/*.zip-old
wp-content/*.gz
wp-content/*.sql

# Logs
*.log
error_log

# OS files
.DS_Store
__MACOSX/
Thumbs.db

# Large archives
*.zip
*.zip-old
*.tar.gz
*.sql
*.sql.gz

# Database backups — never commit production database snapshots
db-backups/

# Node
node_modules/

# Local secrets — never commit
wp-content/themes/salefish/config.local.php
